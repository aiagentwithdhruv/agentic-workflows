# === Agentic Workflows Engine — Environment Variables ===
# Copy this to .env and fill in your values
# NEVER commit .env to git

# --- PRIORITY 1: Euri (Euron AI Gateway — FREE 200K tokens/day) ---
# Sign up: euron.one → Dashboard → API Key
# OpenAI-compatible: use OpenAI SDK with base_url = https://api.euron.one/api/v1/euri
# 24 models: GPT-4o, Claude, Gemini, Llama, Mistral and more
EURI_API_KEY=

# --- PRIORITY 2: OpenRouter (300+ models, all providers in one key) ---
# Sign up: openrouter.ai → free credits on signup
# OpenAI-compatible: use OpenAI SDK with base_url = https://openrouter.ai/api/v1
# Access Claude, GPT-4o, Gemini, Llama, Mistral — everything
OPENROUTER_API_KEY=

# --- Direct providers (optional — if you have keys) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Add tool-specific keys below as you create tools ---
